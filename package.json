{
  "name": "chromepilot",
  "version": "1.0.0",
  "description": "CLI tool to control Chrome via CDP (Chrome DevTools Protocol)",
  "main": "chromepilot.js",
  "bin": {
    "chromepilot": "./chromepilot.js"
  },
  "scripts": {
    "start": "node chromepilot.js",
    "list": "node chromepilot.js list",
    "launch": "bash ./launch-chrome.sh",
    "stop": "bash ./stop-chrome.sh",
    "serve": "node server.js",
    "serve:legacy": "node chromepilot.js serve",
    "start:all": "node ./start-chromepilot.js",
    "install:autostart": "node ./install-autostart.js",
    "test": "node chromepilot.js help"
  },
  "keywords": ["chrome", "cdp", "browser", "automation"],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "chrome-remote-interface": "^0.34.0"
  }
}
